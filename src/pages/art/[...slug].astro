---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const art = await getCollection('art', ({ data }) => data.published);
  return art.map((piece) => ({
    params: { slug: piece.slug },
    props: { piece },
  }));
}

const { piece } = Astro.props;
const { Content } = await piece.render();
---

<ContentLayout
  title={piece.data.title}
  description={piece.data.description}
  date={piece.data.date}
  updated={piece.data.updated}
  tags={piece.data.tags}
>
  {piece.data.image && (
    <div class="relative group cursor-pointer not-prose mb-6" id="art-viewer-trigger">
      {piece.data.image.endsWith('.svg') ? (
        <object
          data={piece.data.image}
          type="image/svg+xml"
          aria-label={piece.data.title}
          class="w-full rounded-lg pointer-events-none"
          id="art-source"
          data-type="svg"
          data-src={piece.data.image}
        />
      ) : (
        <img
          src={piece.data.image}
          alt={piece.data.title}
          class="w-full rounded-lg"
          id="art-source"
          data-type="img"
          data-src={piece.data.image}
        />
      )}
      <div class="absolute inset-0 rounded-lg flex items-end justify-end p-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <span class="text-xs text-text-muted bg-bg/80 backdrop-blur-sm px-2 py-1 rounded">Click to view fullscreen</span>
      </div>
    </div>
  )}
  {piece.data.medium && (
    <p class="text-sm text-text-muted not-prose mb-6">{piece.data.medium}</p>
  )}
  <Content />
</ContentLayout>

<script>
  function setupFullscreen() {
    const trigger = document.getElementById('art-viewer-trigger');
    const source = document.getElementById('art-source');
    if (!trigger || !source) return;

    const srcType = source.getAttribute('data-type');
    const srcUrl = source.getAttribute('data-src');
    let overlay = null;
    let rotation = 0;

    function open() {
      // Build overlay fresh and append to body — escapes all stacking contexts
      rotation = 0;
      overlay = document.createElement('div');
      overlay.id = 'fs-overlay';
      overlay.innerHTML = `
        <div id="fs-content" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;"></div>
        <div style="position:absolute;top:16px;right:16px;display:flex;align-items:center;gap:8px;z-index:10;">
          <button id="fs-rotate" style="display:none;color:rgba(255,255,255,0.6);font-size:18px;padding:8px;background:none;border:none;cursor:pointer;" title="Rotate 90°">&#x21BB;</button>
          <button id="fs-close" style="color:rgba(255,255,255,0.6);font-size:24px;padding:8px;background:none;border:none;cursor:pointer;">&times;</button>
        </div>
      `;
      Object.assign(overlay.style, {
        position: 'fixed',
        inset: '0',
        background: '#000',
        zIndex: '99999',
        opacity: '0',
        transition: 'opacity 400ms ease-out',
      });
      document.body.appendChild(overlay);

      const content = overlay.querySelector('#fs-content');
      if (srcType === 'svg') {
        const obj = document.createElement('object');
        obj.data = srcUrl;
        obj.type = 'image/svg+xml';
        Object.assign(obj.style, { width: '100vw', height: '100vh' });
        content.appendChild(obj);
      } else {
        const img = document.createElement('img');
        img.src = srcUrl;
        img.alt = source.alt || '';
        Object.assign(img.style, {
          maxWidth: '100vw',
          maxHeight: '100vh',
          objectFit: 'contain',
          transition: 'transform 500ms ease-out',
        });
        content.appendChild(img);
        img.onload = function() {
          if (img.naturalWidth !== img.naturalHeight) {
            overlay.querySelector('#fs-rotate').style.display = 'block';
          }
        };
      }

      // Trigger reflow, then fade in
      overlay.offsetHeight;
      overlay.style.opacity = '1';
      document.body.style.overflow = 'hidden';

      // Wire up controls
      overlay.querySelector('#fs-close').addEventListener('click', close);
      overlay.querySelector('#fs-rotate').addEventListener('click', function(e) {
        e.stopPropagation();
        rotation = (rotation + 90) % 360;
        const el = content.firstElementChild;
        if (!el) return;
        const isPortrait = rotation === 90 || rotation === 270;
        el.style.maxWidth = isPortrait ? '100vh' : '100vw';
        el.style.maxHeight = isPortrait ? '100vw' : '100vh';
        el.style.transform = 'rotate(' + rotation + 'deg)';
      });

      // Click backdrop to close
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay || e.target === content) close();
      });

      // Swipe down to close (touch)
      let touchStartY = 0;
      let touchCurrentY = 0;
      let swiping = false;

      overlay.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        touchCurrentY = touchStartY;
        swiping = true;
      }, { passive: true });

      overlay.addEventListener('touchmove', function(e) {
        if (!swiping) return;
        touchCurrentY = e.touches[0].clientY;
        const dy = touchCurrentY - touchStartY;
        if (dy > 0) {
          const el = content.firstElementChild;
          if (el) el.style.transform = 'translateY(' + dy + 'px)';
          overlay.style.opacity = String(Math.max(0, 1 - dy / 300));
        }
      }, { passive: true });

      overlay.addEventListener('touchend', function() {
        if (!swiping) return;
        swiping = false;
        const dy = touchCurrentY - touchStartY;
        if (dy > 120) {
          close();
        } else {
          const el = content.firstElementChild;
          if (el) el.style.transform = '';
          overlay.style.opacity = '1';
        }
      });
    }

    function close() {
      if (!overlay) return;
      overlay.style.opacity = '0';
      document.body.style.overflow = '';
      const el = overlay;
      setTimeout(() => el.remove(), 400);
      overlay = null;
    }

    function onKeydown(e) {
      if (e.key === 'Escape' && overlay) close();
    }

    trigger.addEventListener('click', open);
    document.addEventListener('keydown', onKeydown);
  }

  setupFullscreen();
  document.addEventListener('astro:after-swap', setupFullscreen);
</script>
